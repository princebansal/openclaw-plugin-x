{
  "name": "openclaw-plugin-x",
  "version": "0.2.1",
  "description": "Draft-first X/Twitter management plugin for OpenClaw with OAuth, reads, durable drafts, approval, and guarded publish.",
  "type": "module",
  "main": "dist/plugin-entry.js",
  "types": "dist/plugin-entry.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "env.example",
    "LICENSE",
    "openclaw.plugin.json",
    "plugin.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "twitter",
    "x",
    "agent-tools"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "openclaw": "^2026.4.1",
    "zod": "^3.24.1"
  }
}
