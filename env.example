# Core API defaults
X_API_BASE_URL=https://api.x.com
X_UPLOAD_API_BASE_URL=https://api.x.com
X_OAUTH_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token
X_OAUTH_SCOPES=tweet.read,tweet.write,users.read,follows.read,offline.access,media.write

# OAuth app credentials
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=

# Optional direct token bring-up / persisted session values
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_USER_ID=

# Local durable stores
X_DRAFTS_FILE_PATH=.openclaw-x-drafts.json
X_SESSION_FILE_PATH=.openclaw-x-session.json
